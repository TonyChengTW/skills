# Fun3sport WordPress Docker Skill Set - Environment Configuration
# Copy this file to .env and update the values with your actual credentials

# =============================================================================
# DATABASE CREDENTIALS (REQUIRED)
# These credentials must match your docker-compose.yml database settings
# =============================================================================

# WordPress database user password
DB_PASSWORD=your_db_password_here

# MariaDB root password (for administrative tasks)
DB_ROOT_PASSWORD=your_root_password_here

# =============================================================================
# WORDPRESS SETTINGS (OPTIONAL)
# =============================================================================

# WordPress site URL
WP_URL=http://localhost:8333

# WordPress port
WP_PORT=8333

# =============================================================================
# PROJECT PATHS (OPTIONAL - only change if project is moved)
# =============================================================================

# Project base directory
PROJECT_DIR=/home/fun3sport

# =============================================================================
# BACKUP SETTINGS (OPTIONAL)
# =============================================================================

# Default backup retention days
BACKUP_RETENTION_DAYS=30

# Backup directory (relative to PROJECT_DIR)
BACKUP_DIR=backups

# =============================================================================
# NOTES
# =============================================================================
# 
# 1. NEVER commit the actual .env file to version control!
#    This file (.env.example) is safe to commit as it contains no real credentials.
#
# 2. To use this configuration:
#    cp .env.example .env
#    # Edit .env with your actual values
#
# 3. The skill modules will automatically load values from .env file
#    or from environment variables.
#
# 4. Container names and network names are hardcoded in the skill modules
#    as they are not considered sensitive information:
#    - CONTAINER_WP = "fun3sport_wp"
#    - CONTAINER_DB = "fun3sport_db"
#    - NETWORK_NAME = "fun3sport_net"
#
# =============================================================================
